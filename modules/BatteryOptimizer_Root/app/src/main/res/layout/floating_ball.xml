<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="120dp" android:layout_height="120dp"
    android:background="@drawable/floating_ball_bg">
    <ImageView android:layout_width="48dp" android:layout_height="48dp"
        android:layout_gravity="center" android:src="@drawable/ic_launcher_foreground"/>
    <TextView android:id="@+id/ball_count" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="12dp"
        android:text="0" android:textColor="#FFFFFF" android:textSize="14sp"
        android:textStyle="bold"/>
</FrameLayout>
